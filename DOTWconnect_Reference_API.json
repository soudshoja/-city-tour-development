{
  "metadata": {
    "title": "DOTWconnect Reference Data/Lookup API Methods",
    "source": "DOTWconnect API Documentation",
    "version": "4",
    "last_updated": "2026-03-09",
    "total_methods": 7,
    "purpose": "Reference lookups for country codes, city codes, amenities, chains, classifications, and preferences"
  },

  "countries": {
    "method": "getallcountries",
    "category": "reference_lookup",
    "description": "Retrieve all available countries with their internal codes and regional groupings",
    "endpoint_type": "GET/POST",
    "authentication": "Required",

    "request": {
      "command": "getallcountries",
      "xml_structure": "<request command=\"getallcountries\">\n\t<return>\n\t\t<fields>\n\t\t\t<field>regionName</field>\n\t\t\t<field>regionCode</field>\n\t\t</fields>\n\t</return>\n</request>",
      "parameters": [
        {
          "name": "fields",
          "type": "optional",
          "description": "Specify which fields to return (regionName, regionCode, etc.)"
        }
      ]
    },

    "response": {
      "structure": "<result command=\"getallcountries\" date=\"\">\n\t<countries count=\"\">\n\t\t<country runno=\"\">\n\t\t\t<name></name>\n\t\t\t<code></code>\n\t\t\t<regionName></regionName>\n\t\t\t<regionCode></regionCode>\n\t\t</country>\n\t</countries>\n\t<successful>TRUE</successful>\n</result>",
      "fields": [
        {
          "name": "name",
          "type": "string",
          "description": "Full country name (e.g., 'United States', 'United Kingdom')"
        },
        {
          "name": "code",
          "type": "string",
          "description": "Internal DOTWconnect country code (used throughout API)",
          "important": true
        },
        {
          "name": "regionName",
          "type": "string",
          "description": "Geographic region (e.g., 'Europe', 'Asia', 'North America')"
        },
        {
          "name": "regionCode",
          "type": "string",
          "description": "Region identifier code"
        },
        {
          "name": "count",
          "type": "integer",
          "description": "Total number of countries in response"
        }
      ]
    },

    "usage": {
      "primary_uses": [
        "Get country codes for filter in getservingcities",
        "Populate country selection dropdowns",
        "Validate country input in passenger data",
        "Set passengerNationality in booking requests"
      ],
      "example_code": "const countries = await api.request({ command: 'getallcountries' }); // Use country.code in subsequent calls",
      "notes": "These country codes are REQUIRED for many other API methods - always cache this data at application startup"
    }
  },

  "cities": {
    "method": "getservingcities",
    "category": "reference_lookup",
    "description": "Get serving cities by country, with optional filtering by deals, luxury status, and special offers",
    "endpoint_type": "GET/POST",
    "authentication": "Required",

    "request": {
      "command": "getservingcities",
      "xml_structure": "<request command=\"getservingcities\">\n\t<return>\n\t\t<filters>\n\t\t\t<topDeals>true</topDeals>\n\t\t\t<luxury>true</luxury>\n\t\t\t<specialDeals>true</specialDeals>\n\t\t\t<countryCode></countryCode>\n\t\t\t<countryName></countryName>\n\t\t</filters>\n\t\t<fields>\n\t\t\t<field>countryName</field>\n\t\t\t<field>countryCode</field>\n\t\t</fields>\n\t</return>\n</request>",
      "parameters": [
        {
          "name": "countryCode",
          "type": "string",
          "required": true,
          "description": "Country code from getallcountries - filters cities to this country"
        },
        {
          "name": "countryName",
          "type": "string",
          "required": false,
          "description": "Alternative to countryCode - country name"
        },
        {
          "name": "topDeals",
          "type": "boolean",
          "required": false,
          "description": "Include top deals filter in results"
        },
        {
          "name": "luxury",
          "type": "boolean",
          "required": false,
          "description": "Filter to luxury accommodations"
        },
        {
          "name": "specialDeals",
          "type": "boolean",
          "required": false,
          "description": "Include special promotional deals"
        }
      ]
    },

    "response": {
      "fields": [
        {
          "name": "cities",
          "type": "container",
          "description": "Container element for city list"
        },
        {
          "name": "city",
          "type": "object",
          "attributes": ["runno"],
          "children": [
            {
              "name": "name",
              "type": "string",
              "description": "City name (e.g., 'New York', 'London')"
            },
            {
              "name": "code",
              "type": "string",
              "description": "Internal city code for use in hotel search filters",
              "important": true
            }
          ]
        }
      ]
    },

    "usage": {
      "primary_uses": [
        "Get available cities for a selected country",
        "Populate city selection dropdowns",
        "Use city codes in hotel search requests",
        "Support country/city drill-down navigation"
      ],
      "dependencies": [
        "Requires country code from getallcountries"
      ],
      "example_code": "const cities = await api.request({ command: 'getservingcities', filters: { countryCode: 'US' } }); // Use city.code in searchhotels",
      "notes": "City codes are REQUIRED for hotel search by city - do not use city names directly"
    }
  },

  "hotel_class": {
    "method": "gethotelclassificationids",
    "category": "reference_lookup",
    "description": "Retrieve hotel classification/rating codes (star ratings, quality levels)",
    "endpoint_type": "GET/POST",
    "authentication": "Required",

    "request": {
      "command": "gethotelclassificationids",
      "xml_structure": "<request command=\"gethotelclassificationids\"></request>",
      "parameters": []
    },

    "response": {
      "fields": [
        {
          "name": "hotelclassifications",
          "type": "container",
          "description": "Container for classification list"
        },
        {
          "name": "option",
          "type": "object",
          "attributes": ["runno", "value"],
          "description": "Individual classification option with code and description"
        },
        {
          "name": "successful",
          "type": "boolean",
          "description": "Request success indicator"
        }
      ]
    },

    "usage": {
      "primary_uses": [
        "Get available hotel star ratings or quality levels",
        "Populate hotel class/rating filter dropdowns",
        "Use classification codes in hotel search filters"
      ],
      "example_codes": [
        "1-star, 2-star, 3-star, 4-star, 5-star",
        "Budget, Standard, Superior, Deluxe, Luxury"
      ],
      "notes": "Classification system depends on specific property database and region"
    }
  },

