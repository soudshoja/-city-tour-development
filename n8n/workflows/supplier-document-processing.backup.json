      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\n// Extract request data\nconst body = JSON.stringify($input.all()[0].json.body);\nconst providedSignature = $input.all()[0].json.headers['x-signature'];\nconst timestamp = parseInt($input.all()[0].json.headers['x-timestamp']);\nconst documentId = $input.all()[0].json.body.document_id;\n\n// Check timestamp (replay attack protection - max 5 minutes old)\nconst now = Math.floor(Date.now() / 1000);\nif (Math.abs(now - timestamp) > 300) {\n  throw new Error('ERR_HMAC_INVALID: Timestamp outside acceptable range (replay attack)');\n}\n\n// Get webhook secret from credentials\nconst webhookSecret = $credentials.laravelWebhookSecret.secret;\n\n// Compute HMAC\nconst computedSignature = crypto\n  .createHmac('sha256', webhookSecret)\n  .update(body)\n  .digest('hex');\n\n// Timing-safe comparison\nif (crypto.timingSafeEqual(Buffer.from(providedSignature), Buffer.from(computedSignature))) {\n  // Valid signature - pass through\n  return $input.all()[0].json.body;\n} else {\n  throw new Error(`ERR_HMAC_INVALID: Signature mismatch for document ${documentId}`);\n}"
      },
