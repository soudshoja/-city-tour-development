        "jsCode": "const crypto = require('crypto');\n\n// Build callback payload\nconst callbackPayload = {\n  document_id: $json.document_id,\n  status: $json.extraction_status || 'error',\n  execution_id: $execution.id,\n  workflow_id: $workflow.id,\n  execution_time_ms: Math.floor($execution.resumeTime ? ($execution.resumeTime - $execution.startTime) : 0),\n  extraction_result: $json.extraction_result || null,\n  error: $json.error || null\n};\n\n// Serialize and sign\nconst body = JSON.stringify(callbackPayload);\nconst webhookSecret = $credentials.laravelWebhookSecret.secret;\nconst hmac = crypto.createHmac('sha256', webhookSecret).update(body).digest('hex');\n\nreturn {\n  json: {\n    ...callbackPayload,\n    hmac: hmac\n  }\n};"
